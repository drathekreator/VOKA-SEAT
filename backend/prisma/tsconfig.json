{
  "compilerOptions": {
    "rootDir": ".",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2020",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "isolatedModules": false,
    "verbatimModuleSyntax": false,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["seed.ts"]
}
