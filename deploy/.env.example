# =====================================================================
# VOKA-SEAT deploy/.env.example
#
# Salin ke deploy/.env lalu replace SEMUA nilai sebelum `docker compose up`.
# JANGAN commit deploy/.env ke git.
#
#   cp deploy/.env.example deploy/.env
#   nano deploy/.env
# =====================================================================

# --- Postgres -------------------------------------------------------
# Generate dengan: openssl rand -hex 16
POSTGRES_PASSWORD=change-me-strong-random-password

# --- JWT ------------------------------------------------------------
# Generate dengan: openssl rand -hex 32
JWT_SECRET=change-me-256-bit-hex-secret

# --- Public domain --------------------------------------------------
# Subdomain DuckDNS yang sudah di-register dan resolve ke IP instance.
PUBLIC_DOMAIN_CUSTOMER=vokafe.duckdns.org
PUBLIC_DOMAIN_ADMIN=vokafe-admin.duckdns.org

# --- Admin operator credentials ------------------------------------
# Diseed otomatis ke AdminUser table saat backend boot. Default berikut
# HARUS diganti dengan password kuat untuk deploy production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-admin-password
